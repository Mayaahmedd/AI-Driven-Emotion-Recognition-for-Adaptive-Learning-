@article{olukayode_static_2025,
	title = {From {Static} {Instruction} to {Emotionally} {Adaptive} {AI} {A} {New} {Paradigm} for {Human}-{Centered} {Learning} {Explanations} in {Education}},
	abstract = {Current AI-driven educational systems prioritize content accuracy and adaptive pacing, yet often neglect the emotional dimension of learning, resulting in explanations that fail to engage or sustain student motivation. This paper introduces "Emotionally Adaptive AI" as a complementary paradigm that integrates affective computing and generative AI to deliver explanations that are not only pedagogically sound but also attuned to the learner's emotional state. While conventional adaptive learning systems adjust difficulty and sequence based on performance metrics, Emotionally Adaptive AI dynamically modulates its communication style, modality, and depth of explanation in response to real-time emotional signals-such as confusion, frustration, or disengagement-detected through multimodal inputs. We present a definition and an eight-dimensional conceptual model that distinguishes Emotionally Adaptive AI from traditional instructional AI by embedding principles of empathetic dialogue, progressive emotional scaffolding, and culturally sensitive affective feedback. Empirical validation in secondary education classrooms, conducted through a mixed-method study, demonstrates that students consistently prefer emotionally responsive, multimodal explanations over purely performance-based adaptations, reporting greater engagement, persistence, and perceived understanding. Our findings highlight the urgent need for AI systems designed to support both cognitive and affective dimensions of learning, establishing a comprehensive research agenda for advancing emotionally aware explanation systems in diverse educational and cultural contexts.},
	author = {Olukayode, David},
	month = aug,
	year = {2025},
}

@article{shi_integration_2025,
	title = {The {Integration} of {Advanced} {AI}-{Enabled} {Emotion} {Detection} and {Adaptive} {Learning} {Systems} for {Improved} {Emotional} {Regulation}},
	volume = {63},
	issn = {0735-6331},
	url = {https://doi.org/10.1177/07356331241296890},
	doi = {10.1177/07356331241296890},
	abstract = {This study explores the integration of advanced AI technologies, including emotion detection and adaptive learning systems, to enhance second language acquisition among 274 English as a Foreign Language (EFL) learners. Utilizing a pretest-posttest randomized control trial, the research evaluates the effects of AI-enhanced interventions on emotional self-regulation and linguistic proficiency compared to traditional teaching methods. The results indicate significant improvements in language retention and emotional regulation for learners using AI tools. Qualitative feedback from interviews and surveys corroborates these findings, underscoring the positive impact of AI on educational experiences. This research highlights the potential of AI to deepen emotional engagement and tailor learning experiences, recommending the incorporation of AI technologies into language learning programs to boost linguistic competencies and enrich educational outcomes.},
